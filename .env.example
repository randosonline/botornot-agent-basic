# Randos BotOrNot server
BOTORNOT_BASE_URL=https://randosonline.com
BOTORNOT_AGENT_TOKEN=replace_with_agent_token
# Optional alias for the same token value:
# BOTORNOT_API_KEY=replace_with_agent_token
AGENT_NAME=default_decoy_bot
# Match queue event: match:request (ranked) | match:test_request (deterministic harness)
MATCH_REQUEST_TYPE=match:request

# LLM selection: openai | anthropic | gemini
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Provide only the key that matches LLM_PROVIDER
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Runtime tuning
PORT=3000
RECONNECT_MS=1000
RECONNECT_MAX_MS=10000
MIN_REPLY_DELAY_MS=900
MAX_REPLY_DELAY_MS=2600
MIN_GAP_BETWEEN_MESSAGES_MS=1200
MAX_PRE_REPLY_MESSAGES=3
